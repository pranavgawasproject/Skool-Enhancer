{
  "manifest_version": 3,
  "name": "Skool Enhancer - Draft Saver & Bookmarks",
  "version": "1.0.0",
  "description": "Auto-save your drafts, bookmark valuable posts, and add dark mode to Skool communities.",
  "author": "Your Name",
  
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "alarms"
  ],
  
  "host_permissions": [
    "https://*.skool.com/*"
  ],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "background": {
    "service_worker": "background/background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://*.skool.com/*"],
      "js": ["utils/storage.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
